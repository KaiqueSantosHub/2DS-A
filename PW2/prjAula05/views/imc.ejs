     <!DOCTYPE html>
     <html lang="pt-br">
     <head>
     <meta charset="UTF-8">
     <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <title> IMC do usuário</title>
     <link rel="stylesheet" href="/imc.css">
     </head>
     <body>

        <div class="conteiner">

    
    <div class="opcao">
        <h1 class="tituloNavagacao">Navegação</h1>
        <a href="/reajuste"> Reajuste </a>
        <a href="/aluno"> Aluno </a>
        <a href="/pagamento"> Pagamento </a>
    </div>

    
    <div class="formArea">

        <form action="/imc" method="get">
            <h1 class="tituloForms">Índice de Massa Corporal</h1>
            <input type="number" name="peso" placeholder="Insira seu peso (Kg)">
            <input type="number" name="altura" placeholder="Insira sua altura (Cm)">
            <button type="submit"> Calcule seu IMC</button>
        </form>

        
        <div class="resultado <%= mostrarDados ? 'ativo' : '' %>">

     <% if (mostrarDados) { %>


          
     <% if (imc < 18.5){ %>
          <p>IMC: <%= imc %> - Abaixo do peso</p>
     <% } else if (imc >= 18.6 &&  imc <=  24.9) { %>
          <p>IMC: <%= imc %> - Peso ideal. Parabéns!</p>
     <% } else if (imc >= 25 &&  imc <= 29.9) { %>
          <p>IMC: <%= imc %> - Levemente acima do peso</p>
     <% } else if (imc >= 30 &&  imc <= 34.9) { %>
          <p>IMC: <%= imc %> - Obesidade grau I</p>
     <% } else if (imc >= 35 &&  imc <= 39.9) { %>
          <p>IMC: <%= imc %> - Obesidade grau II (severa) </p>
     <% } else if (imc>=40) { %>
          <p>IMC: <%= imc %> - Obesidade grau III (mórbida) </p>
     <% } %>
                    
          <% } %>   
          
        

    </div>

</div>
     
     </body>
     </html>